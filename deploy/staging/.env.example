# Slack設定
# Slack App の OAuth & Permissions から取得
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Slack App の Basic Information > App Credentials から取得
SLACK_SIGNING_SECRET=your-slack-signing-secret-here

# GitHub Webhook設定（オプション）
# GitHub Repository の Settings > Webhooks で設定したシークレット
# 空の場合は署名検証をスキップ
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here

# ログレベル設定
# 値: debug, info, warn, error
# ステージング環境では debug も有効
LOG_LEVEL=info

# データベース設定
# docker-compose.yml で設定されているため、通常は変更不要
# DB_PATH=/app/data/staging_review_tasks.db

# Nginx設定（HTTPS使用時）
# SSL証明書のドメイン名
# DOMAIN=staging.example.com

# Let's Encrypt設定（証明書自動取得時）
# LETSENCRYPT_EMAIL=admin@example.com

# バックアップ設定
# バックアップの保持日数（デフォルト: 7日）
# BACKUP_RETENTION_DAYS=7

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# GitHub Configuration
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Database Configuration
DB_PATH=review_tasks.db

# Test Environment Variables (for staging/integration tests)
# These variables are used when running integration tests against a real Slack workspace

# Slack Test Workspace Token
# This should be a bot token from your test Slack workspace
SLACK_TEST_WORKSPACE_TOKEN=xoxb-your-test-workspace-token

# Slack Test Channel ID
# The channel ID where test messages will be sent (e.g., C01234ABCDE)
SLACK_TEST_CHANNEL_ID=your-test-channel-id

# Slack Test User ID
# The user ID for testing user-related features (e.g., U01234ABCDE)
SLACK_TEST_USER_ID=your-test-user-id

# GitHub Test Webhook Secret
# Secret used for testing GitHub webhook signature verification
GITHUB_TEST_WEBHOOK_SECRET=your-test-github-webhook-secret

# Test Mode Flag
# Set to 'true' to enable test mode, 'false' for production mode
TEST_MODE=false

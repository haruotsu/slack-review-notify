# テスト環境用の環境変数設定
# 実際のトークンは使用せず、テスト用のダミー値を設定してください

# Slack設定
SLACK_BOT_TOKEN=xoxb-test-token-for-local-testing
SLACK_SIGNING_SECRET=test-signing-secret-replace-me

# GitHub設定
GITHUB_WEBHOOK_SECRET=test-webhook-secret-replace-me

# データベース設定
DB_PATH=/app/data/test_review_tasks.db

# その他の設定
# LOG_LEVEL=debug
